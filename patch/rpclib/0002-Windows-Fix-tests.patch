From 4170c63355bad5e206a1cd983aa8b2cf9d3a9d6e Mon Sep 17 00:00:00 2001
From: Jerome Haxhiaj <jhaxhiaj@qti.qualcomm.com>
Date: Mon, 9 Mar 2026 08:44:57 +0100
Subject: [PATCH 2/2] Windows: Fix tests

- Enable threads
- Use ip address 127.0.0.1 instead of localhost to reduce test duration.

Signed-off-by: Jerome Haxhiaj <jhaxhiaj@qti.qualcomm.com>
---
 tests/CMakeLists.txt             | 14 ++++++++++++++
 tests/rpc/client_test.cc         |  2 +-
 tests/rpc/server_session_test.cc |  8 ++++----
 3 files changed, 19 insertions(+), 5 deletions(-)

diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index 1f0419e..1d2f462 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -25,6 +25,20 @@ target_include_directories(${TEST_PROJECT_NAME}
 
 target_link_libraries(${TEST_PROJECT_NAME} ${PROJECT_NAME} Threads::Threads)
 
+# Windows with Clang: ASIO doesn't detect threads correctly (no _MSC_VER)
+if(WIN32)
+  target_compile_definitions(${TEST_PROJECT_NAME} PRIVATE
+    ASIO_HAS_THREADS=1
+  )
+endif()
+
+# Define Windows version for ASIO
+if(WIN32)
+  target_compile_definitions(${TEST_PROJECT_NAME} PRIVATE
+    _WIN32_WINNT=0x0A00  # Windows 10
+  )
+endif()
+
 # Set less strict warning for tests, since google test is not quite
 # warning-clean
 if (${CMAKE_CXX_COMPILER_ID} MATCHES "Clang")
diff --git a/tests/rpc/client_test.cc b/tests/rpc/client_test.cc
index a3b56f6..c47a3be 100644
--- a/tests/rpc/client_test.cc
+++ b/tests/rpc/client_test.cc
@@ -121,7 +121,7 @@ TEST_F(client_test, bad_ip) {
 }
 
 TEST(client_test2, timeout_while_connection) {
-    rpc::client client("localhost", rpc::constants::DEFAULT_PORT);
+    rpc::client client("127.0.0.1", rpc::constants::DEFAULT_PORT);
     client.set_timeout(50);
 #ifdef __linux__
     // this client never connects, so this tests the timout in wait_conn()
diff --git a/tests/rpc/server_session_test.cc b/tests/rpc/server_session_test.cc
index 276d46f..2dc8e67 100644
--- a/tests/rpc/server_session_test.cc
+++ b/tests/rpc/server_session_test.cc
@@ -46,14 +46,14 @@ TEST_F(server_session_test, connection_closed_properly) {
 	const unsigned max_tries = 1000;
 #endif
     for (unsigned counter = 0; counter < max_tries; ++counter) {
-        rpc::client client("localhost", rpc::constants::DEFAULT_PORT);
+        rpc::client client("127.0.0.1", rpc::constants::DEFAULT_PORT);
         auto response = client.call("func");
     }
     // no crash is enough
 }
 
 TEST_F(server_session_test, session_id_unique) {
-    rpc::client c2("localhost", rpc::constants::DEFAULT_PORT);
+    rpc::client c2("127.0.0.1", rpc::constants::DEFAULT_PORT);
     auto sid1 = c.call("get_sid").as<rpc::session_id_t>();
     auto sid2 = c2.call("get_sid").as<rpc::session_id_t>();
     EXPECT_NE(sid1, sid2);
@@ -67,7 +67,7 @@ TEST(server_session_test_bug153, bug_153_crash_on_client_timeout) {
     });
     s.async_run();
 
-    auto client = std::unique_ptr<rpc::client>(new rpc::client("localhost", rpc::constants::DEFAULT_PORT));
+    auto client = std::unique_ptr<rpc::client>(new rpc::client("127.0.0.1", rpc::constants::DEFAULT_PORT));
     client->set_timeout(5);
 
     try {
@@ -94,7 +94,7 @@ TEST(server_session_test_bug175, bug_175_multhread_crash) {
 
     auto spam_call = [&](int idx, int nr_calls) {
         for (int i=0; i<nr_calls; ++i) {
-            auto client = std::unique_ptr<rpc::client>(new rpc::client("localhost", rpc::constants::DEFAULT_PORT));
+            auto client = std::unique_ptr<rpc::client>(new rpc::client("127.0.0.1", rpc::constants::DEFAULT_PORT));
             client->call("bug_175", idx, i);
         }
     };
